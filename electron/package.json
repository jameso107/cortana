{
  "name": "cortana",
  "version": "1.0.0",
  "description": "Cortana — local AI assistant",
  "main": "main.js",
  "author": "James Oosterhouse",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.cortana.app",
    "productName": "Cortana",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [{ "target": "dmg", "arch": ["arm64"] }],
      "icon": "assets/icon.icns"
    },
    "dmg": {
      "title": "Cortana"
    },
    "extraResources": [
      { "from": "../ui/dist",  "to": "ui/dist"  },
      { "from": "../cortana",  "to": "cortana"  },
      { "from": "../config",   "to": "config"   }
    ],
    "files": ["main.js", "preload.js", "splash.html", "assets/**"]
  }
}
