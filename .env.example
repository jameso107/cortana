# Local OpenAI-powered agent (never expose this to the browser or commit a value)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Authenticated web application
CORTANA_SESSION_SECRET=
CORTANA_ACCESS_KEY_HASH=
CORTANA_BRIDGE_URL=wss://localhost:8765
CORTANA_BRIDGE_TOKEN=

# Local privileged bridge
CORTANA_ALLOWED_ORIGINS=http://localhost:3000
CORTANA_TLS_CERT=~/.cortana/certs/localhost.pem
CORTANA_TLS_KEY=~/.cortana/certs/localhost-key.pem
